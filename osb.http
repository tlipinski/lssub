# opensubtitles

###
# @name formats
GET {{url}}/api/v1/infos/formats
Api-Key: {{key}}

###
# @name subtitles
GET {{url}}/api/v1/subtitles?
    query=mr robot&
    languages=pl
Api-Key: {{key}}

###
# @name download
POST {{url}}/api/v1/download
Api-Key: {{key}}
Content-Type: application/json

{
  "file_id": 10798997
}

###
# @name features
GET {{url}}/api/v1/subtitles?
    query=mr robot s01e01&
    languages=pl
Api-Key: {{key}}

###
GET https://www.opensubtitles..Side.Effects.S01E01.Pilot.1080p.MAX.WEB-DL.H264-playWEB.srt

###
# @name user info
GET {{urlvip}}/api/v1/infos/user
Authorization: Bearer {{jwt}}
Api-Key: {{key}}
Content-Type: application/json

###
# @name user info
GET {{url}}/api/v1/infos/user
Api-Key: {{key}}
Content-Type: application/json
